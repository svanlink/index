# Optional cloud sync configuration for packaged builds
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional:
# VITE_SUPABASE_SCHEMA=public

# Release candidate or release tag used by the operator checklist
# Example: v1.0.0-rc1
# RELEASE_TAG=

# macOS signing and notarization inputs
# These are examples only. Do not commit real secrets.
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Company, Inc. (TEAMID1234)
APPLE_TEAM_ID=TEAMID1234
APPLE_ID=release-operator@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional CI/base64 certificate flow
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
