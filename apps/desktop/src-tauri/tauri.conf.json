{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Catalog",
  "version": "1.0.0-rc1",
  "identifier": "com.driveprojectcatalog.app",
  "build": {
    "beforeDevCommand": "corepack pnpm dev:frontend",
    "beforeBuildCommand": "corepack pnpm build:frontend",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Catalog",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business"
  }
}
