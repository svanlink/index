{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drive Project Catalog",
  "version": "0.1.0",
  "identifier": "com.driveprojectcatalog.app",
  "build": {
    "beforeDevCommand": "corepack pnpm dev:web",
    "beforeBuildCommand": "corepack pnpm build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Drive Project Catalog",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
